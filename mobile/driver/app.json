{
  "expo": {
    "name": "BizPrint Driver",
    "slug": "bizprint-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "bizprint-driver",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mn.bizprint.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Хүргэлтийн байршил хянахад ашиглана",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Хүргэлтийн явцад байршил илгээхэд ашиглана",
        "NSCameraUsageDescription": "Хүргэлтийн баталгаажуулалтын зураг авахад ашиглана"
      }
    },
    "android": {
      "package": "mn.bizprint.driver",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000",
      "eas": { "projectId": "" }
    }
  }
}
