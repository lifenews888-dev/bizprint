{
  "name": "bizprint",
  "version": "1.0.0",
  "private": true,
  "description": "BizPrint — Mongolian print-on-demand e-commerce platform",
  "workspaces": [
    "backend",
    "frontend",
    "packages/shared",
    "mobile/customer",
    "mobile/driver",
    "mobile/courier",
    "mobile/staff",
    "mobile/admin"
  ],
  "scripts": {
    "backend": "cd backend && npm run start:dev",
    "frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bizprintpro-alt/bizprint.git"
  },
  "license": "ISC",
  "overrides": {
    "customer": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    },
    "driver": {
      "react": "18.3.1"
    },
    "courier": {
      "react": "18.3.1"
    },
    "staff": {
      "react": "18.3.1"
    },
    "admin": {
      "react": "18.3.1"
    }
  },
  "dependencies": {
    "metro": "^0.81.5",
    "metro-cache": "^0.81.5",
    "metro-cache-key": "^0.81.5",
    "metro-core": "^0.81.5",
    "metro-file-map": "^0.81.5",
    "metro-minify-terser": "^0.81.5",
    "metro-resolver": "^0.81.5",
    "metro-runtime": "^0.81.5",
    "metro-source-map": "^0.81.5",
    "metro-symbolicate": "^0.81.5",
    "metro-transform-plugins": "^0.81.5",
    "metro-transform-worker": "^0.81.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
