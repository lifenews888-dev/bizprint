# ─────────────────────────────────────────────────────────────────────────────
#  BizPrint — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=bizprint

# ── Authentication (JWT) ─────────────────────────────────────────────────────
# SECURITY: Change JWT_SECRET to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail example: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587
# Use App Password if using Gmail (not your real password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_app_password
MAIL_FROM=BizPrint <noreply@bizprint.mn>

# ── Zoom API (Server-to-Server OAuth) ────────────────────────────────────────
# Create at: https://marketplace.zoom.us/develop/create
# App type: Server-to-Server OAuth
# Required scopes: meeting:write:admin
# Leave empty to use designer's personal Zoom link as fallback
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Zoom Webhook verification secret (from Zoom App → Feature → Webhook)
ZOOM_WEBHOOK_SECRET=

# ── Google Calendar API (OAuth2) ────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API
# OAuth2 consent → get refresh token via playground: https://developers.google.com/oauthplayground
# Required scope: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Frontend ─────────────────────────────────────────────────────────────────
# For local dev: http://localhost:4000
# For Docker:    http://backend:4000 (build arg) + http://localhost:4000 (runtime browser)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── User Roles (reference) ───────────────────────────────────────────────────
# admin    → /admin
# vendor   → /dashboard/vendor
# customer → /dashboard/customer
# designer → /designer/approval
# sales    → /dashboard/sales
# courier  → /dashboard
# factory  → /dashboard/factory
