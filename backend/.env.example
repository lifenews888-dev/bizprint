# ─── BizPrint Backend Environment Variables ─────────
# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=production

# Database (Railway auto-provides DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/bizprint
DATABASE_SSL=true

# Or individual DB vars (local dev)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=postgres
# DB_NAME=bizprint

# JWT
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated production origins)
CORS_ORIGINS=https://bizprint.mn,https://customer.bizprint.mn,https://admin.bizprint.mn

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# POS Webhook
POS_WEBHOOK_SECRET=your-webhook-secret
